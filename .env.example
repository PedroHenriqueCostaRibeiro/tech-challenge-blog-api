# Servidor
PORT=3000

# Banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=blog

# Sincroniza o schema automaticamente a partir das entidades (use apenas em dev).
# Em producao, prefira migrations e deixe como false.
DB_SYNCHRONIZE=true
DB_LOGGING=false
